<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Mountain background silhouettes -->
    <path
        android:fillColor="#E0E0E0"
        android:pathData="M10,90 L40,40 L70,90 Z" />
    <path
        android:fillColor="#BDBDBD"
        android:pathData="M40,90 L75,30 L108,90 Z" />

    <!-- The iconic Stelvio zig-zag road -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineJoin="round"
        android:strokeLineCap="round"
        android:pathData="M30,85 L80,85 L25,75 L85,75 L20,65 L90,65 L15,55 L95,55 L25,45 L85,45 L40,35" />

    <!-- Road center line (dashed effect using a second thinner stroke) -->
    <path
        android:strokeColor="#BDBDBD"
        android:strokeWidth="0.5"
        android:strokeLineJoin="round"
        android:strokeLineCap="round"
        android:pathData="M30,85 L80,85 L25,75 L85,75 L20,65 L90,65 L15,55 L95,55 L25,45 L85,45 L40,35" />

    <!-- A small motorcycle/rider hint at the top or bottom?
         Let's keep it clean with just the road and peaks. -->

</vector>