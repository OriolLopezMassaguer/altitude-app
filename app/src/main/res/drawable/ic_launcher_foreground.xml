    android:viewportHeight="108">

    <!-- Subtle Sun/Glow behind the peak -->
    <path android:pathData="M54,25 A12,12 0 1,1 54,49 A12,12 0 1,1 54,25">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="37"
                android:gradientRadius="12"
                android:type="radial">
                <item android:offset="0" android:color="#40FFFFFF"/>
                <item android:offset="1" android:color="#00FFFFFF"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Cervino / Matterhorn Main Body -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M22,82 L52,18 L62,32 L68,48 L88,82 Z" />

    <!-- Dramatic Shading on the steep face -->
