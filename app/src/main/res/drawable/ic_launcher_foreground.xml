        android:fillColor="#CFD8DC"
        android:pathData="M52,18 L62,32 L68,48 L56,82 L52,82 Z" />

    <!-- Highlighted Snow line on the ridge -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M52,18 L62,32 L68,48" />

    <!-- Mist / Clouds at the base for depth -->
    <path
        android:fillColor="#33FFFFFF"
        android:pathData="M15,75 Q30,68 54,75 Q78,82 93,75 L93,85 L15,85 Z" />

